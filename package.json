{
	"name": "gatekeeper",
	"version": "1.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"build": "npm run build:dashboard && npm run build:cli",
		"build:dashboard": "npm run --prefix dashboard build",
		"build:cli": "tsc -p cli/tsconfig.json",
		"typecheck": "tsc --noEmit && tsc -p cli/tsconfig.json --noEmit",
		"lint": "prettier --check 'src/**/*.ts' 'cli/**/*.ts' 'test/**/*.ts'",
		"lint:fix": "prettier --write 'src/**/*.ts' 'cli/**/*.ts' 'test/**/*.ts'",
		"test": "vitest run",
		"test:worker": "vitest run -c vitest.worker.config.ts",
		"test:cli": "vitest run -c vitest.cli.config.ts",
		"preflight": "npm run typecheck && npm run lint && npm test && npm run build",
		"deploy": "npm run build:dashboard && wrangler deploy",
		"ship": "npm run preflight && npm run deploy",
		"cf-typegen": "wrangler types",
		"cli": "node --env-file=.env --import tsx cli/index.ts",
		"smoke": "node --env-file=.env --import tsx cli/smoke-test.ts"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.19",
		"@types/node": "^25.3.3",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.70.0"
	},
	"dependencies": {
		"aws4fetch": "^1.0.20",
		"citty": "^0.2.1",
		"hono": "^4.12.5"
	}
}
