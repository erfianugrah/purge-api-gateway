---
import "../styles/globals.css";

interface Props {
  title?: string;
  active?: string;
}

const { title = "gatekeeper", active = "overview" } = Astro.props;

const navLinks = [
  { id: "overview", label: "Overview", href: "/dashboard", icon: "grid", section: "" },
  { id: "purge", label: "Purge", href: "/dashboard/purge", icon: "zap", section: "Operations" },
  { id: "keys", label: "Purge Keys", href: "/dashboard/keys", icon: "key", section: "Access" },
  { id: "s3-credentials", label: "S3 Credentials", href: "/dashboard/s3-credentials", icon: "s3", section: "Access" },
  { id: "upstream-tokens", label: "Upstream Tokens", href: "/dashboard/upstream-tokens", icon: "token", section: "Upstream" },
  { id: "upstream-r2", label: "Upstream R2", href: "/dashboard/upstream-r2", icon: "bucket", section: "Upstream" },
  { id: "analytics", label: "Analytics", href: "/dashboard/analytics", icon: "list", section: "Observability" },
  { id: "settings", label: "Settings", href: "/dashboard/settings", icon: "settings", section: "System" },
];

// Track which sections we've already rendered a header for
const seenSections = new Set<string>();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="h-screen overflow-hidden bg-background text-foreground antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside
        id="sidebar"
        class="hidden w-60 flex-shrink-0 overflow-y-auto border-r border-border bg-lovelace-950 md:block"
      >
        <div class="flex h-full flex-col">
          <!-- Logo area -->
          <div class="flex h-14 items-center gap-2 border-b border-border px-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-md bg-lv-purple/10">
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
              >
                <path class="text-lv-purple" d="M12 2 L3 6.5 L3 12 C3 18.5 6.8 23 12 24.5 C17.2 23 21 18.5 21 12 L21 6.5 Z" stroke="currentColor" />
                <circle cx="12" cy="11" r="2.5" fill="currentColor" class="text-lv-purple" />
                <rect x="11" y="13" width="2" height="4" rx="0.8" fill="currentColor" class="text-lv-purple" />
              </svg>
            </div>
            <span
              class="text-sm font-bold tracking-wider text-lv-purple glow-purple"
            >
               GATEKEEPER
            </span>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 space-y-1 px-2 py-4">
            {
              navLinks.map((link) => {
                const showHeader = link.section && !seenSections.has(link.section);
                if (showHeader) seenSections.add(link.section);
                return (
                  <>
                    {showHeader && (
                      <div class="px-3 pt-4 pb-1">
                        <span class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground/60">
                          {link.section}
                        </span>
                      </div>
                    )}
                    <a
                      href={link.href}
                      class:list={[
                        "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                        active === link.id
                          ? "bg-lv-purple/10 text-lv-purple"
                          : "text-muted-foreground hover:bg-accent hover:text-foreground",
                      ]}
                    >
                      {/* Grid / Overview */}
                      {link.icon === "grid" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <rect x="3" y="3" width="7" height="7" />
                          <rect x="14" y="3" width="7" height="7" />
                          <rect x="3" y="14" width="7" height="7" />
                          <rect x="14" y="14" width="7" height="7" />
                        </svg>
                      )}
                      {/* Key */}
                      {link.icon === "key" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" />
                        </svg>
                      )}
                      {/* List / Analytics */}
                      {link.icon === "list" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <line x1="8" y1="6" x2="21" y2="6" />
                          <line x1="8" y1="12" x2="21" y2="12" />
                          <line x1="8" y1="18" x2="21" y2="18" />
                          <line x1="3" y1="6" x2="3.01" y2="6" />
                          <line x1="3" y1="12" x2="3.01" y2="12" />
                          <line x1="3" y1="18" x2="3.01" y2="18" />
                        </svg>
                      )}
                      {/* Zap / Purge */}
                      {link.icon === "zap" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                        </svg>
                      )}
                      {/* S3 / Cloud Storage */}
                      {link.icon === "s3" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4" />
                          <path d="M14 2v5h5" />
                          <path d="M3 15h6" />
                          <path d="M6 12l-3 3 3 3" />
                        </svg>
                      )}
                      {/* Token / Shield */}
                      {link.icon === "token" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                      )}
                      {/* Bucket / Database */}
                      {link.icon === "bucket" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <ellipse cx="12" cy="5" rx="9" ry="3" />
                          <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                          <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                        </svg>
                      )}
                      {/* Settings / Gear */}
                      {link.icon === "settings" && (
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <circle cx="12" cy="12" r="3" />
                          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
                        </svg>
                      )}
                      <span>{link.label}</span>
                    </a>
                  </>
                );
              })
            }
          </nav>

          <!-- Footer -->
          <div class="border-t border-border px-4 py-3">
            <div class="text-xs text-muted-foreground">Gatekeeper</div>
          </div>
        </div>
      </aside>

      <!-- Main content area -->
      <div class="flex flex-1 flex-col overflow-hidden">
        <!-- Header -->
        <header
          class="flex h-14 items-center justify-between border-b border-border bg-lovelace-950/50 px-6"
        >
          <!-- Mobile menu button -->
          <button
            class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent md:hidden"
            aria-label="Toggle menu"
            id="mobile-menu-btn"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>

          <h1 class="text-sm font-medium text-foreground">
            {title}
          </h1>

          <div class="flex items-center gap-3">
            <!-- Status indicator -->
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-lv-green opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2 w-2 rounded-full bg-lv-green"
                ></span>
              </span>
              <span class="text-xs text-muted-foreground">HEALTHY</span>
            </div>
          </div>
        </header>

        <!-- Page content -->
        <main id="main-content" class="flex-1 overflow-y-auto p-6">
          <slot />

          <!-- Scroll to top button -->
          <button
            id="scroll-top-btn"
            class="fixed bottom-6 right-6 z-40 hidden h-10 w-10 items-center justify-center rounded-full border border-border bg-lovelace-950/90 text-muted-foreground shadow-lg backdrop-blur-sm transition-all hover:bg-accent hover:text-foreground"
            aria-label="Scroll to top"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="18 15 12 9 6 15" />
            </svg>
          </button>
        </main>
      </div>
    </div>

    <!-- Scroll to top -->
    <script>
      const mainEl = document.getElementById("main-content");
      const scrollBtn = document.getElementById("scroll-top-btn");
      if (mainEl && scrollBtn) {
        mainEl.addEventListener("scroll", () => {
          if (mainEl.scrollTop > 400) {
            scrollBtn.classList.remove("hidden");
            scrollBtn.classList.add("flex");
          } else {
            scrollBtn.classList.add("hidden");
            scrollBtn.classList.remove("flex");
          }
        });
        scrollBtn.addEventListener("click", () => {
          mainEl.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>

    <!-- Mobile nav overlay -->
    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const sidebar = document.getElementById("sidebar");
      if (btn && sidebar) {
        btn.addEventListener("click", () => {
          sidebar.classList.toggle("hidden");
          sidebar.classList.toggle("fixed");
          sidebar.classList.toggle("inset-0");
          sidebar.classList.toggle("z-50");
          sidebar.classList.toggle("w-60");
        });
        // Close sidebar when clicking a link on mobile
        sidebar.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            if (sidebar.classList.contains("fixed")) {
              sidebar.classList.add("hidden");
              sidebar.classList.remove("fixed", "inset-0", "z-50");
            }
          });
        });
      }
    </script>
  </body>
</html>
