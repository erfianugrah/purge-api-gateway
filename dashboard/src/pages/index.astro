---
// Splash page — shown briefly before redirecting to /dashboard/
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gatekeeper</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: #15161e;
        color: #fcfcfc;
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        overflow: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* Subtle radial glow behind the logo */
      .backdrop-glow {
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse 600px 400px at 50% 45%, rgba(197,116,221,0.08) 0%, transparent 70%);
        pointer-events: none;
        z-index: 0;
      }

      .splash {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        animation: fadeIn 0.6s ease-out both;
      }

      /* Shield icon */
      .shield {
        width: 64px;
        height: 64px;
        animation: floatIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .shield path { stroke: #c574dd; }
      .shield circle, .shield rect { fill: #c574dd; }

      /* Title */
      .title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #c574dd;
        text-shadow:
          0 0 10px rgba(197,116,221,0.5),
          0 0 20px rgba(197,116,221,0.3),
          0 0 40px rgba(197,116,221,0.1);
        animation: fadeIn 0.8s ease-out 0.2s both;
      }

      /* Progress bar */
      .progress-track {
        width: 160px;
        height: 2px;
        background: #343647;
        border-radius: 1px;
        overflow: hidden;
        animation: fadeIn 0.6s ease-out 0.4s both;
      }
      .progress-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #c574dd, #8796f4);
        border-radius: 1px;
        animation: fill 1.2s ease-in-out 0.5s forwards;
      }

      /* Subtitle / link */
      .subtitle {
        font-size: 0.75rem;
        color: #bdbdc1;
        animation: fadeIn 0.6s ease-out 0.5s both;
      }
      .subtitle a {
        color: #c574dd;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
      }
      .subtitle a:hover {
        border-bottom-color: #c574dd;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes floatIn {
        from { opacity: 0; transform: translateY(-12px) scale(0.9); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes fill {
        to { width: 100%; }
      }
    </style>
  </head>
  <body>
    <div class="backdrop-glow"></div>

    <div class="splash">
      <!-- Shield logo (matches sidebar) -->
      <svg class="shield" viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linejoin="round">
        <path d="M12 2 L3 6.5 L3 12 C3 18.5 6.8 23 12 24.5 C17.2 23 21 18.5 21 12 L21 6.5 Z" />
        <circle cx="12" cy="11" r="2.5" />
        <rect x="11" y="13" width="2" height="4" rx="0.8" />
      </svg>

      <div class="title">Gatekeeper</div>

      <div class="progress-track">
        <div class="progress-fill"></div>
      </div>

      <div class="subtitle" id="quip"></div>

      <noscript>
        <div class="subtitle">
          <a href="/dashboard/">Continue to dashboard</a>
        </div>
      </noscript>
    </div>

    <script is:inline>
      var quips = [
        'You shall not pass... without valid credentials.',         // LotR — used in auth guards everywhere
        'sudo make me a sandwich.',                                 // xkcd #149
        'correct horse battery staple.',                            // xkcd #936
        'All your base are belong to us.',                          // Zero Wing
        "There's no place like 127.0.0.1.",                         // Classic sysadmin
        'Follow the white rabbit.',                                 // The Matrix
        "I'm in.",                                                  // Every hacker movie ever
        'Trust, but verify.',                                       // Zero Trust doctrine
        'It works on my machine.',                                  // Universal dev truth
        'Have you tried turning it off and on again?',              // IT Crowd
        'Authorization: Bearer of good news.',                      // HTTP header pun
        'There are only 10 types of people in the world.',          // Binary joke
        'The cloud is just someone else\u2019s computer.',          // Infosec proverb
        '// TODO: fix this later.',                                 // Found in every codebase
        'rm -rf / for free WiFi.',                                  // Hak5 SSID payloads
        'SELECT * FROM users WHERE clue > 0; -- 0 rows returned.', // SQL humor
        'Roses are #FF0000, violets are #0000FF.',                  // Programmer poetry
        'Works as designed. Not as expected.',                       // QA proverb
        'The S in IoT stands for Security.',                        // Infosec truism
        'HTTP 418: I\u2019m a teapot.',                             // RFC 2324
        'It\u2019s not DNS. There\u2019s no way it\u2019s DNS. It was DNS.', // Every sysadmin ever
      ];
      document.getElementById('quip').textContent = quips[Math.floor(Math.random() * quips.length)];
      setTimeout(function () { window.location.href = '/dashboard/'; }, 1700);
    </script>
  </body>
</html>
